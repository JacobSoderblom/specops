{
  "name": "specops",
  "version": "0.1.0",
  "description": "Agent operating system for AI-assisted software development. Scaffolds governance, workflows, and coordination for AI agents working on codebases.",
  "type": "module",
  "bin": {
    "specops": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "src/templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "claude",
    "claude-code",
    "developer-tools",
    "scaffolding",
    "governance",
    "workflows",
    "exec-plans",
    "architecture"
  ],
  "author": "Jacob Soderblom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacobsoderblom/specops.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.3.7",
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
